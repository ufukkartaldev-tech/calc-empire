# CalcEmpire Environment Variables

# Base URL for the application (used in sitemap, metadata, etc.)
NEXT_PUBLIC_BASE_URL=https://calcempire.com

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console Verification (optional)
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your-verification-code

# Yandex Verification (optional)
# NEXT_PUBLIC_YANDEX_VERIFICATION=your-verification-code
